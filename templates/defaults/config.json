{
  "version": "1.0.0",
  "plugin_name": "gran-maestro",
  "branding": {
    "name": "Gran Maestro",
    "tagline": "I am the Maestro — I conduct, I don't code."
  },
  "server": {
    "port": 3847,
    "host": "127.0.0.1"
  },
  "workflow": {
    "max_feedback_rounds": 5,
    "auto_approve_spec": false,
    "auto_accept_result": true,
    "default_agent": "codex-dev",
    "spec_prereview": true,
    "spec_prereview_max_iterations": 3,
    "spec_prereview_escalation_trigger": "major",
    "spec_prereview_minor_escalation_threshold": 3,
    "auto_approve_on_unblock": false
  },
  "concurrency": {
    "max_parallel_tasks": 5,
    "max_parallel_reviews": 3,
    "batch_max_parallel_reqs": 1,
    "queue_strategy": "fifo"
  },
  "timeouts": {
    "cli_default_ms": 300000,
    "cli_large_task_ms": 1800000,
    "pre_check_ms": 120000,
    "merge_ms": 60000,
    "user_approval_ms": null,
    "dashboard_health_check_ms": 10000,
    "wait_files_ms": 600000
  },
  "worktree": {
    "root_directory": ".gran-maestro/worktrees",
    "max_active": 10,
    "base_branch": "main",
    "stale_timeout_hours": 24,
    "auto_cleanup_on_cancel": true
  },
  "retry": {
    "max_cli_retries": 2,
    "max_fallback_depth": 1,
    "backoff_base_ms": 1000
  },
  "history": {
    "retention_days": 30,
    "auto_archive": true
  },
  "archive": {
    "max_active_sessions": 20,
    "archive_retention_days": null,
    "auto_archive_on_create": true,
    "auto_archive_on_complete": true,
    "archive_directory": ".gran-maestro/archive"
  },
  "notifications": {
    "terminal": true,
    "dashboard": true
  },
  "realtime": {
    "protocol": "sse",
    "debounce_ms": 100
  },
  "debug": {
    "enabled": false,
    "log_level": "info",
    "log_prompts": false,
    "agents": {
      "codex": {
        "count": 1,
        "tier": "premium"
      },
      "gemini": {
        "count": 1,
        "tier": "premium"
      },
      "claude": {
        "count": 0
      }
    }
  },
  "explore": {
    "agents": {
      "codex": {
        "count": 1,
        "tier": "premium"
      },
      "gemini": {
        "count": 1,
        "tier": "premium"
      },
      "claude": {
        "count": 0
      }
    }
  },
  "discussion": {
    "agents": {
      "codex": {
        "count": 1,
        "tier": "premium"
      },
      "gemini": {
        "count": 1,
        "tier": "premium"
      },
      "claude": {
        "count": 1,
        "tier": "economy"
      }
    },
    "response_char_limit": 2000,
    "critique_char_limit": 2000,
    "default_max_rounds": 5,
    "max_rounds_upper_limit": 10
  },
  "ideation": {
    "agents": {
      "codex": {
        "count": 1,
        "tier": "premium"
      },
      "gemini": {
        "count": 1,
        "tier": "premium"
      },
      "claude": {
        "count": 1,
        "tier": "economy"
      }
    },
    "opinion_char_limit": 2000,
    "critique_char_limit": 2000
  },
  "collaborative_debug": {
    "finding_char_limit": 3000,
    "merge_wait_ms": 60000,
    "auto_trigger_from_start": true
  },
  "prereview": {
    "agents": {
      "codex": {
        "count": 1,
        "tier": "premium"
      },
      "gemini": {
        "count": 0
      },
      "claude": {
        "count": 1,
        "tier": "economy"
      }
    }
  },
  "models": {
    "providers": {
      "codex": {
        "premium": "gpt-5.3-codex",
        "economy": "codex-mini",
        "default_tier": "premium"
      },
      "gemini": {
        "premium": "gemini-3.1-pro-preview",
        "economy": "gemini-2.5-flash",
        "default_tier": "premium"
      },
      "claude": {
        "premium": "opus",
        "economy": "sonnet",
        "default_tier": "economy"
      }
    },
    "roles": {
      "pm_conductor": {
        "provider": "claude",
        "tier": "premium"
      },
      "architect": {
        "provider": "claude",
        "tier": "premium"
      },
      "developer": [
        {
          "provider": "codex",
          "tier": "premium"
        },
        {
          "provider": "gemini",
          "tier": "premium"
        }
      ],
      "developer_claude": {
        "provider": "claude",
        "tier": "premium"
      },
      "reviewer": [
        {
          "provider": "codex",
          "tier": "premium"
        },
        {
          "provider": "gemini",
          "tier": "premium"
        }
      ]
    }
  },
  "code_review": {
    "enabled": true,
    "agents": 1,
    "agent_roster": [
      "codex",
      "gemini"
    ],
    "parallel": true
  },
  "cleanup": {
    "ideation_keep_count": 10,
    "discussion_keep_count": 10,
    "debug_keep_count": 10,
    "plan_keep_count": 10,
    "request_keep_count": 10,
    "old_request_threshold_hours": 24
  },
  "stitch": {
    "enabled": true,
    "auto_detect": true,
    "auto_trigger": false,
    "project_id": null,
    "model_id": "GEMINI_3_PRO",
    "failure_policy": "skip",
    "ui_keywords": {
      "whitelist": [
        "화면",
        "페이지",
        "UI",
        "레이아웃",
        "컴포넌트",
        "모달",
        "폼",
        "버튼",
        "스크린",
        "디자인",
        "목업",
        "시안",
        "screen",
        "layout",
        "component",
        "modal"
      ],
      "blacklist": [
        "API",
        "DB",
        "데이터베이스",
        "테스트",
        "배포",
        "알고리즘",
        "스키마",
        "백엔드"
      ]
    }
  },
  "plan_review": {
    "enabled": true,
    "parallel": true,
    "max_iterations": 2,
    "escalation_trigger": "major",
    "minor_escalation_threshold": 3,
    "roles": {
      "architect": {
        "enabled": true,
        "agent": "codex"
      },
      "devils_advocate": {
        "enabled": true,
        "agent": "gemini"
      },
      "completeness": {
        "enabled": true,
        "agent": "codex"
      },
      "ux_reviewer": {
        "enabled": true,
        "agent": "gemini"
      }
    }
  },
  "review": {
    "auto_review": true,
    "max_iterations": 3,
    "severity_auto_fix": {
      "enabled": true,
      "minor_skip_threshold": 3,
      "pm_direct_fix_enabled": true,
      "pm_direct_fix_max_files": 1,
      "pm_direct_fix_max_diff_lines": 20,
      "security_override_keywords": [
        "인증",
        "인가",
        "인젝션",
        "시크릿",
        "XSS",
        "CSRF",
        "SQL injection",
        "권한 우회",
        "authentication",
        "authorization",
        "injection",
        "secret",
        "token",
        "경로 탐색",
        "path traversal",
        "코드 인젝션",
        "code injection",
        "자격 증명",
        "API 키"
      ]
    },
    "roles": {
      "code_reviewer": {
        "agent": "codex"
      },
      "arch_reviewer": {
        "agent": "gemini"
      },
      "ui_reviewer": {
        "agent": "gemini"
      }
    }
  },
  "phase1_exploration": {
    "roles": {
      "symbol_tracing": {
        "agent": "codex",
        "enabled": true,
        "tier": "premium"
      },
      "broad_scan": {
        "agent": "gemini",
        "enabled": true,
        "tier": "premium"
      }
    }
  }
}
