{
  "models": {
    "claude": {
      "pm_conductor": "opus",
      "architect": "opus",
      "ideation": "opus",
      "discussion": "opus",
      "debug": "opus",
      "prereview": "opus"
    },
    "gemini": { "default": "gemini-3.1-pro-preview" },
    "developer": {
      "primary": { "provider": "gemini", "model": "gemini-3.1-pro-preview" },
      "fallback": { "provider": "gemini", "model": "gemini-3.1-pro-preview" },
      "claude_dev": { "provider": "claude", "model": "opus" }
    },
    "reviewer": {
      "primary": { "provider": "gemini", "model": "gemini-3.1-pro-preview" },
      "fallback": { "provider": "gemini", "model": "gemini-3.1-pro-preview" }
    }
  },
  "ideation": { "agents": { "codex": 0, "gemini": 2, "claude": 1 } },
  "discussion": { "agents": { "codex": 0, "gemini": 2, "claude": 1 } },
  "debug": { "agents": { "codex": 0, "gemini": 2, "claude": 1 } },
  "explore": { "agents": { "codex": 0, "gemini": 2, "claude": 0 } },
  "prereview": { "agents": { "codex": 0, "gemini": 1, "claude": 1 } },
  "code_review": { "agents": 2, "agent_roster": ["codex", "gemini"] },
  "plan_review": { "enabled": true, "parallel": true },
  "phase1_exploration": {
    "roles": {
      "symbol_tracing": { "agent": "codex", "enabled": true },
      "broad_scan": { "agent": "gemini", "enabled": true }
    }
  }
}
